PUID=1000
PGID=1000
TZ=America/Sao_Paulo

# flaresolverr port (default 8191)
PORT=8191

# Beszel agent SSH public key — generated by the Beszel hub after first
# admin login (UI: Add System -> shown in the docker run snippet). Until
# this is set, the beszel-agent container will not start.
BESZEL_HUB_KEY=

# Homepage widget secrets — needed for HA + AdGuard live widgets
# HA: Profile -> Security -> Long-Lived Access Tokens -> Create
# AdGuard: your AdGuardHome login password
HA_TOKEN=
ADGUARD_PASSWORD=
